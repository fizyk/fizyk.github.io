&lt;a id="rest_code_1b4a0e5a66374301979f6fe89db2c102-9" name="rest_code_1b4a0e5a66374301979f6fe89db2c102-9" href="https://fizyk.dev/pl/blog/python-i-wszystko-jest-obiektem/#rest_code_1b4a0e5a66374301979f6fe89db2c102-9"&gt;&lt;/a&gt;&lt;span class="o"&gt;&amp;gt;&amp;gt;&amp;gt;&lt;/span&gt; &lt;span class="nb"&gt;len&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="nb"&gt;dir&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="nb"&gt;dir&lt;/span&gt;&lt;span class="p"&gt;))&lt;/span&gt;
&lt;a id="rest_code_1b4a0e5a66374301979f6fe89db2c102-10" name="rest_code_1b4a0e5a66374301979f6fe89db2c102-10" href="https://fizyk.dev/pl/blog/python-i-wszystko-jest-obiektem/#rest_code_1b4a0e5a66374301979f6fe89db2c102-10"&gt;&lt;/a&gt;&lt;span class="mi"&gt;26&lt;/span&gt;
&lt;a id="rest_code_1b4a0e5a66374301979f6fe89db2c102-11" name="rest_code_1b4a0e5a66374301979f6fe89db2c102-11" href="https://fizyk.dev/pl/blog/python-i-wszystko-jest-obiektem/#rest_code_1b4a0e5a66374301979f6fe89db2c102-11"&gt;&lt;/a&gt;&lt;span class="o"&gt;&amp;gt;&amp;gt;&amp;gt;&lt;/span&gt; &lt;span class="nb"&gt;len&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="nb"&gt;dir&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="nb"&gt;len&lt;/span&gt;&lt;span class="p"&gt;))&lt;/span&gt;
&lt;a id="rest_code_1b4a0e5a66374301979f6fe89db2c102-12" name="rest_code_1b4a0e5a66374301979f6fe89db2c102-12" href="https://fizyk.dev/pl/blog/python-i-wszystko-jest-obiektem/#rest_code_1b4a0e5a66374301979f6fe89db2c102-12"&gt;&lt;/a&gt;&lt;span class="mi"&gt;26&lt;/span&gt;
