&lt;p&gt;I niespodzianka:&lt;/p&gt;
&lt;div class="code"&gt;&lt;pre class="code python"&gt;&lt;a id="rest_code_acfc2be4948445a3a36753fa9c10f60b-1" name="rest_code_acfc2be4948445a3a36753fa9c10f60b-1" href="https://fizyk.dev/pl/blog/python-i-wszystko-jest-obiektem/#rest_code_acfc2be4948445a3a36753fa9c10f60b-1"&gt;&lt;/a&gt;&lt;span class="o"&gt;&amp;gt;&amp;gt;&amp;gt;&lt;/span&gt; &lt;span class="nb"&gt;len&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="nb"&gt;dir&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="nb"&gt;print&lt;/span&gt;&lt;span class="p"&gt;))&lt;/span&gt;
&lt;a id="rest_code_acfc2be4948445a3a36753fa9c10f60b-2" name="rest_code_acfc2be4948445a3a36753fa9c10f60b-2" href="https://fizyk.dev/pl/blog/python-i-wszystko-jest-obiektem/#rest_code_acfc2be4948445a3a36753fa9c10f60b-2"&gt;&lt;/a&gt;  &lt;span class="n"&gt;File&lt;/span&gt; &lt;span class="s2"&gt;"&amp;lt;stdin&amp;gt;"&lt;/span&gt;&lt;span class="p"&gt;,&lt;/span&gt; &lt;span class="n"&gt;line&lt;/span&gt; &lt;span class="mi"&gt;1&lt;/span&gt;
&lt;a id="rest_code_acfc2be4948445a3a36753fa9c10f60b-3" name="rest_code_acfc2be4948445a3a36753fa9c10f60b-3" href="https://fizyk.dev/pl/blog/python-i-wszystko-jest-obiektem/#rest_code_acfc2be4948445a3a36753fa9c10f60b-3"&gt;&lt;/a&gt;    &lt;span class="nb"&gt;len&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="nb"&gt;dir&lt;/span&gt;&lt;span class="p"&gt;(&lt;/span&gt;&lt;span class="nb"&gt;print&lt;/span&gt;&lt;span class="p"&gt;))&lt;/span&gt;
&lt;a id="rest_code_acfc2be4948445a3a36753fa9c10f60b-4" name="rest_code_acfc2be4948445a3a36753fa9c10f60b-4" href="https://fizyk.dev/pl/blog/python-i-wszystko-jest-obiektem/#rest_code_acfc2be4948445a3a36753fa9c10f60b-4"&gt;&lt;/a&gt;            &lt;span class="o"&gt;^&lt;/span&gt;
&lt;a id="rest_code_acfc2be4948445a3a36753fa9c10f60b-5" name="rest_code_acfc2be4948445a3a36753fa9c10f60b-5" href="https://fizyk.dev/pl/blog/python-i-wszystko-jest-obiektem/#rest_code_acfc2be4948445a3a36753fa9c10f60b-5"&gt;&lt;/a&gt;&lt;span class="ne"&gt;SyntaxError&lt;/span&gt;&lt;span class="p"&gt;:&lt;/span&gt; &lt;span class="n"&gt;invalid&lt;/span&gt; &lt;span class="n"&gt;syntax&lt;/span&gt;
